# FinWise AI — Environment Variables
#
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored and must NEVER be committed.
#
# The Groq API key is read ONLY on the server (src/services/groq.ts) and is
# never exposed to the browser. Do not prefix it with PUBLIC_.

# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ---- Google Sheets cloud storage (Prompt 7) --------------------------------
# Deploy the Apps Script in docs/google-apps-script.gs as a Web App and paste
# its /exec URL here. Read ONLY on the server (src/services/googleSheets.ts) and
# never exposed to the browser. If unset, the app stores history locally and
# syncs automatically once this is configured.
GOOGLE_SCRIPT_URL=your_apps_script_web_app_url_here

# Optional shared secret. If set here, set the SAME value in the Apps Script
# (SCRIPT_TOKEN) to reject unauthenticated writes. Leave blank to disable.
GOOGLE_SCRIPT_TOKEN=

