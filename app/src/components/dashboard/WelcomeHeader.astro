---
import Icon from '../Icon.astro';

interface Props {
  name?: string;
}

const { name = 'Siva' } = Astro.props;
---

<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
  <div>
    <span class="eyebrow">Financial Intelligence</span>
    <h1 class="mt-2 font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl">
      Welcome back, {name}
    </h1>
    <p class="mt-1.5 text-sm text-ink-subtle md:text-base">
      Here's a snapshot of your financial health and recent activity.
    </p>
  </div>

  <div class="flex shrink-0 items-center gap-2">
    <a href="/history" class="btn-secondary">
      <Icon name="history" size="16" />
      View History
    </a>
    <a href="/loan-eligibility" class="btn-primary">
      <Icon name="plus" size="16" />
      New Analysis
    </a>
  </div>
</div>
