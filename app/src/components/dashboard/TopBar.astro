---
import Icon from '../Icon.astro';
---

<header
  class="sticky top-0 z-30 flex h-14 items-center gap-3 border-b border-hairline bg-canvas/80 px-4 backdrop-blur-md sm:px-6"
>
  <!-- Mobile: open sidebar drawer -->
  <button
    id="sidebar-toggle"
    type="button"
    class="inline-flex h-10 w-10 items-center justify-center rounded-md text-ink lg:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-focus/50"
    aria-label="Open navigation"
    aria-controls="dashboard-sidebar"
    aria-expanded="false"
  >
    <Icon name="menu" size="20" />
  </button>

  <!-- Search -->
  <div class="relative hidden max-w-xs flex-1 items-center sm:flex">
    <span class="pointer-events-none absolute left-3 text-ink-subtle">
      <Icon name="search" size="16" />
    </span>
    <input
      type="search"
      placeholder="Search tools, history…"
      aria-label="Search"
      class="h-9 w-full rounded-md border border-hairline bg-surface-1 pl-9 pr-3 text-sm text-ink placeholder:text-ink-tertiary focus:border-hairline-strong focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-focus/50"
    />
  </div>

  <div class="ml-auto flex items-center gap-2">
    <!-- Notifications -->
    <div class="relative" data-menu-root>
      <button
        id="notif-trigger"
        type="button"
        class="relative inline-flex h-10 w-10 items-center justify-center rounded-md text-ink-subtle transition-colors hover:bg-surface-2 hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-focus/50"
        aria-label="Notifications"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="notif-panel"
        data-menu-trigger
      >
        <Icon name="bell" size="18" />
      </button>

      <div
        id="notif-panel"
        class="topbar-menu absolute right-0 top-full mt-2 hidden w-72 origin-top-right"
        role="menu"
        aria-labelledby="notif-trigger"
        data-menu-panel
      >
        <div class="glass-card overflow-hidden p-0">
          <div class="flex items-center justify-between border-b border-hairline px-4 py-3">
            <p class="text-sm font-semibold text-ink">Notifications</p>
          </div>
          <!-- Empty state -->
          <div class="flex flex-col items-center justify-center px-6 py-8 text-center">
            <span class="flex h-11 w-11 items-center justify-center rounded-full bg-surface-2 text-ink-subtle">
              <Icon name="bell" size="20" />
            </span>
            <p class="mt-3 text-sm font-medium text-ink">No notifications yet.</p>
            <p class="mt-1 text-xs text-ink-subtle">You're all caught up.</p>
          </div>
        </div>
      </div>
    </div>

    <a href="/loan-eligibility" class="btn-primary hidden sm:inline-flex">
      <Icon name="plus" size="16" />
      New Analysis
    </a>

    <!-- Account menu -->
    <div class="relative" data-menu-root>
      <button
        id="account-trigger"
        type="button"
        class="flex items-center gap-2 rounded-md p-1 pr-2 transition-colors hover:bg-surface-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-focus/50"
        aria-label="Account menu"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="account-panel"
        data-menu-trigger
      >
        <span class="flex h-8 w-8 items-center justify-center rounded-full bg-surface-2 text-ink-muted">
          <Icon name="user" size="16" />
        </span>
        <span class="hidden text-ink-subtle md:inline">
          <Icon name="chevron-down" size="16" />
        </span>
      </button>

      <div
        id="account-panel"
        class="topbar-menu absolute right-0 top-full mt-2 hidden w-60 origin-top-right"
        role="menu"
        aria-labelledby="account-trigger"
        data-menu-panel
      >
        <div class="glass-card overflow-hidden p-0">
          <div class="border-b border-hairline px-4 py-3">
            <p class="text-sm font-semibold text-ink">FinWise User</p>
            <p class="mt-0.5 truncate text-xs text-ink-subtle">Demo account</p>
          </div>
          <div class="p-1.5">
            <button type="button" class="topbar-menu-item" role="menuitem" data-action="profile">
              <Icon name="user" size="16" />
              <span>Profile</span>
            </button>
            <button type="button" class="topbar-menu-item" role="menuitem" data-action="coming-soon">
              <Icon name="settings" size="16" />
              <span>Settings</span>
              <span class="topbar-menu-badge">Coming Soon</span>
            </button>
            <button type="button" class="topbar-menu-item" role="menuitem" data-action="coming-soon">
              <Icon name="help-circle" size="16" />
              <span>Help &amp; Support</span>
              <span class="topbar-menu-badge">Coming Soon</span>
            </button>
          </div>
          <div class="border-t border-hairline p-1.5">
            <button
              type="button"
              class="topbar-menu-item text-ink-tertiary"
              role="menuitem"
              disabled
              aria-disabled="true"
              tabindex="-1"
            >
              <Icon name="log-out" size="16" />
              <span>Sign Out</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .topbar-menu {
    z-index: 40;
  }
  .topbar-menu-item {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.625rem;
    border-radius: 0.375rem;
    padding: 0.5rem 0.625rem;
    text-align: left;
    font-size: 0.875rem;
    color: var(--color-ink-subtle, currentColor);
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .topbar-menu-item:not(:disabled):hover,
  .topbar-menu-item:not(:disabled):focus-visible {
    background-color: rgb(255 255 255 / 0.06);
    color: var(--color-ink, currentColor);
    outline: none;
  }
  .topbar-menu-item:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }
  .topbar-menu-item > span:first-of-type {
    flex: 1 1 auto;
  }
  .topbar-menu-badge {
    flex: 0 0 auto;
    border-radius: 9999px;
    border: 1px solid var(--color-hairline, rgb(255 255 255 / 0.1));
    padding: 0.125rem 0.5rem;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-tertiary, currentColor);
  }
</style>

<script>
  import { showToast } from '../../utils/toast';

  // ---- Sidebar drawer (mobile) ----------------------------------------------
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('dashboard-sidebar');
  const backdrop = document.getElementById('sidebar-backdrop');

  if (toggle && sidebar && backdrop) {
    const open = () => {
      sidebar.classList.remove('-translate-x-full');
      backdrop.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      sidebar.querySelector('a')?.focus();
    };

    const close = () => {
      sidebar.classList.add('-translate-x-full');
      backdrop.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.focus();
    };

    toggle.addEventListener('click', () => {
      if (sidebar.classList.contains('-translate-x-full')) {
        open();
      } else {
        close();
      }
    });

    backdrop.addEventListener('click', close);
    sidebar.querySelectorAll('a').forEach((link) => link.addEventListener('click', close));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') close();
    });
  }

  // ---- Top-bar dropdown menus (notifications + account) ---------------------
  // A tiny accessible menu controller shared by both dropdowns: click to toggle,
  // ESC / outside-click to close, arrow-key navigation, and a focus trap so Tab
  // stays within the open panel. Only one menu is open at a time.
  interface Menu {
    root: HTMLElement;
    trigger: HTMLElement;
    panel: HTMLElement;
    items: HTMLElement[];
  }

  const menus: Menu[] = Array.from(
    document.querySelectorAll<HTMLElement>('[data-menu-root]')
  )
    .map((root): Menu | null => {
      const trigger = root.querySelector<HTMLElement>('[data-menu-trigger]');
      const panel = root.querySelector<HTMLElement>('[data-menu-panel]');
      if (!trigger || !panel) return null;
      return { root, trigger, panel, items: [] };
    })
    .filter((m): m is Menu => m !== null);

  function focusableItems(menu: Menu): HTMLElement[] {
    return Array.from(
      menu.panel.querySelectorAll<HTMLElement>(
        '[role="menuitem"]:not([disabled]):not([aria-disabled="true"])'
      )
    );
  }

  function openMenu(menu: Menu, focusFirst = false) {
    // Close any other open menu first.
    for (const other of menus) {
      if (other !== menu) closeMenu(other);
    }
    menu.panel.classList.remove('hidden');
    menu.trigger.setAttribute('aria-expanded', 'true');
    menu.items = focusableItems(menu);
    if (focusFirst && menu.items.length > 0) {
      menu.items[0].focus();
    }
  }

  function closeMenu(menu: Menu, restoreFocus = false) {
    if (menu.panel.classList.contains('hidden')) return;
    menu.panel.classList.add('hidden');
    menu.trigger.setAttribute('aria-expanded', 'false');
    if (restoreFocus) menu.trigger.focus();
  }

  function isOpen(menu: Menu): boolean {
    return !menu.panel.classList.contains('hidden');
  }

  for (const menu of menus) {
    menu.trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      if (isOpen(menu)) closeMenu(menu);
      else openMenu(menu);
    });

    // Open with arrow keys from the trigger and land on the first item.
    menu.trigger.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        openMenu(menu, true);
      }
    });

    // Keyboard behavior within an open panel: focus trap + roving arrows.
    menu.panel.addEventListener('keydown', (e) => {
      const items = menu.items.length ? menu.items : focusableItems(menu);
      if (items.length === 0) return;
      const currentIndex = items.indexOf(document.activeElement as HTMLElement);

      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu(menu, true);
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        items[(currentIndex + 1 + items.length) % items.length]?.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        items[(currentIndex - 1 + items.length) % items.length]?.focus();
      } else if (e.key === 'Home') {
        e.preventDefault();
        items[0]?.focus();
      } else if (e.key === 'End') {
        e.preventDefault();
        items[items.length - 1]?.focus();
      } else if (e.key === 'Tab') {
        // Trap focus inside the panel while it's open.
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // Menu-item actions (account menu).
    menu.panel.querySelectorAll<HTMLElement>('[data-action]').forEach((item) => {
      item.addEventListener('click', () => {
        const action = item.dataset.action;
        if (action === 'coming-soon') {
          showToast('Coming in Portfolio Version', { variant: 'info' });
        } else if (action === 'profile') {
          showToast('Coming in Portfolio Version', { variant: 'info' });
        }
        closeMenu(menu, true);
      });
    });
  }

  // Close on outside click.
  document.addEventListener('click', (e) => {
    for (const menu of menus) {
      if (isOpen(menu) && !menu.root.contains(e.target as Node)) {
        closeMenu(menu);
      }
    }
  });

  // Global ESC (e.g. focus is on the trigger, not inside the panel).
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    for (const menu of menus) {
      if (isOpen(menu)) closeMenu(menu, true);
    }
  });
</script>
