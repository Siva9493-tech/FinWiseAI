---
import Icon from './Icon.astro';

interface Step {
  number: string;
  icon: string;
  title: string;
  description: string;
}

const steps: Step[] = [
  {
    number: '01',
    icon: 'smartphone',
    title: 'Enter your details',
    description:
      'Share basic financial information — income, expenses, existing loans, and goals — through a clean, guided form.',
  },
  {
    number: '02',
    icon: 'gauge',
    title: 'Run analysis',
    description:
      'Our calculators evaluate eligibility, credit health, and EMI affordability using deterministic financial formulas.',
  },
  {
    number: '03',
    icon: 'sparkles',
    title: 'Get AI insights',
    description:
      'FinWise AI explains results, highlights risks, and suggests practical next steps tailored to your profile.',
  },
  {
    number: '04',
    icon: 'trending-up',
    title: 'Take action',
    description:
      'Compare options, track your analysis history, and move forward with confidence on your financial journey.',
  },
];
---

<section id="how-it-works" class="border-b border-hairline bg-canvas py-20 md:py-24 lg:py-32">
  <div class="section-container">
    <div class="mx-auto max-w-3xl text-center">
      <span class="eyebrow">How It Works</span>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink md:text-4xl lg:text-5xl">
        From data to decision in four simple steps
      </h2>
      <p class="mt-4 text-lg text-ink-subtle">
        FinWise AI combines precise calculations with intelligent guidance so you always know your next move.
      </p>
    </div>

    <div class="relative mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div class="absolute top-11 left-0 hidden h-px w-full bg-gradient-to-r from-transparent via-hairline to-transparent lg:block"></div>

      {steps.map((step) => (
        <div class="relative z-10 flex flex-col items-center text-center">
          <div class="flex h-20 w-20 items-center justify-center rounded-full border border-hairline bg-surface-1 shadow-sm top-edge-highlight">
            <Icon name={step.icon} size="24" />
          </div>
          <div class="mt-6 flex h-7 items-center justify-center rounded-full bg-surface-2 px-3 text-xs font-medium text-ink-subtle">
            Step {step.number}
          </div>
          <h3 class="mt-4 text-lg font-semibold tracking-tight text-ink">{step.title}</h3>
          <p class="mt-2 max-w-xs text-sm leading-relaxed text-ink-subtle">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
