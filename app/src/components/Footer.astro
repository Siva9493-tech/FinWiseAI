---
import Icon from './Icon.astro';

const productLinks = [
  { label: 'Loan Eligibility', href: '/loan-eligibility' },
  { label: 'Credit Score Analyzer', href: '/credit-score' },
  { label: 'EMI Calculator', href: '/emi-calculator' },
  { label: 'AI Advisor', href: '/ai-advisor' },
];

const companyLinks = [
  { label: 'About', href: '#' },
  { label: 'Roadmap', href: '#' },
  { label: 'Privacy', href: '#' },
  { label: 'Terms', href: '#' },
];

const resourceLinks = [
  { label: 'Documentation', href: '#' },
  { label: 'Blog', href: '#' },
  { label: 'GitHub', href: '#' },
  { label: 'Support', href: '#' },
];
---

<footer class="border-t border-hairline bg-canvas">
  <div class="section-container py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <a href="#" class="flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-focus/50 rounded-md">
          <span class="flex h-7 w-7 items-center justify-center rounded-md bg-primary text-on-primary">
            <Icon name="sparkles" size="16" />
          </span>
          <span class="text-base font-semibold tracking-tight text-ink">FinWise AI</span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-subtle">
          Intelligent loan eligibility, credit analysis, EMI planning, and AI-powered financial guidance — all in one place.
        </p>
        <p class="mt-6 text-xs text-ink-tertiary">
          © {new Date().getFullYear()} FinWise AI. Built for the SmartBridge Vibe Coding Internship.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-muted">Product</h4>
        <ul class="mt-4 space-y-2.5">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-ink-subtle transition-colors hover:text-ink focus:outline-none focus-visible:text-ink"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-muted">Company</h4>
        <ul class="mt-4 space-y-2.5">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-ink-subtle transition-colors hover:text-ink focus:outline-none focus-visible:text-ink"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-muted">Resources</h4>
        <ul class="mt-4 space-y-2.5">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-ink-subtle transition-colors hover:text-ink focus:outline-none focus-visible:text-ink"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</footer>
