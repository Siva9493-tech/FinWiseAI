---
import Icon from './Icon.astro';
---

<section class="relative overflow-hidden border-b border-hairline">
  <div class="absolute inset-0 bg-dot-pattern opacity-50"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>

  <div class="section-container relative z-10 pt-14 pb-20 md:pt-20 md:pb-28 lg:pt-24 lg:pb-32">
    <div class="mx-auto max-w-4xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-hairline bg-surface-1 px-3 py-1.5 shadow-sm">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
        </span>
        <span class="text-xs font-medium text-ink-muted">AI-powered financial intelligence</span>
      </div>

      <h1 class="font-display text-4xl font-semibold leading-[1.05] tracking-tight text-ink md:text-5xl lg:text-6xl xl:text-7xl">
        Make smarter financial decisions with <span class="text-primary">FinWise AI</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-subtle md:text-xl">
        Check loan eligibility, analyze credit scores, calculate EMIs, and receive personalized
        guidance — all powered by intelligent AI that puts your financial future first.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="#cta" class="btn-primary px-5 py-2.5 text-base">
          Get Started Free
          <Icon name="arrow-right" size="16" />
        </a>
        <a href="#features" class="btn-secondary px-5 py-2.5 text-base">
          <Icon name="play" size="16" />
          Explore Features
        </a>
      </div>

      <p class="mt-4 text-xs text-ink-tertiary" aria-hidden="true">No credit card required. Built for everyone.</p>
    </div>

    <div class="mx-auto mt-16 max-w-5xl">
      <div class="relative rounded-xl border border-hairline bg-surface-1 p-2 shadow-2xl top-edge-highlight md:rounded-2xl md:p-3">
        <div class="overflow-hidden rounded-lg bg-canvas md:rounded-xl">
          <div class="border-b border-hairline bg-surface-2 px-4 py-3">
            <div class="flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-hairline-strong"></div>
              <div class="h-3 w-3 rounded-full bg-hairline-strong"></div>
              <div class="h-3 w-3 rounded-full bg-hairline-strong"></div>
              <span class="ml-3 text-xs font-medium text-ink-tertiary">FinWise AI Dashboard Preview</span>
            </div>
          </div>
          <div class="grid gap-px bg-hairline sm:grid-cols-2 lg:grid-cols-4">
            <div class="bg-surface-1 p-5">
              <Icon name="landmark" size="20" />
              <p class="mt-3 text-sm text-ink-subtle">Loan Eligibility</p>
              <p class="mt-1 text-2xl font-semibold tracking-tight text-ink">87%</p>
              <p class="mt-1 text-xs text-success">High approval chance</p>
            </div>
            <div class="bg-surface-1 p-5">
              <Icon name="credit-card" size="20" />
              <p class="mt-3 text-sm text-ink-subtle">Credit Score</p>
              <p class="mt-1 text-2xl font-semibold tracking-tight text-ink">742</p>
              <p class="mt-1 text-xs text-ink-subtle">Good</p>
            </div>
            <div class="bg-surface-1 p-5">
              <Icon name="calculator" size="20" />
              <p class="mt-3 text-sm text-ink-subtle">EMI Estimate</p>
              <p class="mt-1 text-2xl font-semibold tracking-tight text-ink">₹18,420</p>
              <p class="mt-1 text-xs text-ink-subtle">Per month</p>
            </div>
            <div class="bg-surface-1 p-5">
              <Icon name="brain" size="20" />
              <p class="mt-3 text-sm text-ink-subtle">AI Advisor</p>
              <p class="mt-1 text-2xl font-semibold tracking-tight text-ink">On</p>
              <p class="mt-1 text-xs text-ink-subtle">Personalized plan</p>
            </div>
          </div>
          <div class="border-t border-hairline bg-surface-1 p-5">
            <div class="flex items-start gap-4">
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary">
                <Icon name="sparkles" size="14" />
              </div>
              <div>
                <p class="text-sm font-medium text-ink">AI Recommendation</p>
                <p class="mt-1 text-sm leading-relaxed text-ink-subtle">
                  Based on your profile, reduce existing credit utilization by 12% before applying
                  for a personal loan to unlock better interest rates.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
