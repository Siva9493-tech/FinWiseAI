---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import Icon from '../components/Icon.astro';

// History — Recent Analyses from cloud (Google Sheets) merged with any local,
// not-yet-synced snapshots. All data loading, search, filtering, and the detail
// view are handled by the client script below via the history service.
const filterOptions = [
  { value: 'all', label: 'All analyses' },
  { value: 'loan', label: 'Loan' },
  { value: 'credit', label: 'Credit' },
  { value: 'emi', label: 'EMI' },
  { value: 'advisor', label: 'AI Advice' },
];
---

<DashboardLayout
  title="History — FinWise AI"
  description="Your recent financial analyses — loan eligibility, credit score, EMI, and AI advice — saved securely to the cloud."
  active="History"
>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <span class="eyebrow">Cloud Storage</span>
        <h1 class="mt-2 font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl">
          History
        </h1>
        <p class="mt-1.5 max-w-2xl text-sm text-ink-subtle md:text-base">
          Every analysis you run is saved automatically. Search, filter, and open
          any record to see the full result exactly as it was generated.
        </p>
      </div>
      <!-- Sync status pill -->
      <span
        id="sync-status"
        class="inline-flex items-center gap-1.5 rounded-full border border-hairline bg-surface-1 px-3 py-1.5 text-xs font-medium text-ink-subtle"
      >
        <Icon name="cloud" size="14" />
        <span id="sync-status-text">Loading…</span>
      </span>
    </div>

    <!-- Toolbar -->
    <div class="glass-card flex flex-col gap-3 p-4 sm:flex-row sm:items-center">
      <div class="relative flex-1">
        <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-ink-subtle">
          <Icon name="search" size="16" />
        </span>
        <input
          id="history-search"
          type="search"
          placeholder="Search by name, status, rating, or summary…"
          aria-label="Search analyses"
          class="field-control pl-9"
        />
      </div>
      <div class="flex items-center gap-2">
        <label for="history-filter" class="sr-only">Filter by tool</label>
        <div class="relative">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-ink-subtle">
            <Icon name="filter" size="15" />
          </span>
          <select id="history-filter" class="field-control w-full pl-9 sm:w-44">
            {filterOptions.map((o) => <option value={o.value}>{o.label}</option>)}
          </select>
        </div>
        <button id="history-refresh" type="button" class="btn-secondary h-10 px-3 text-sm" aria-label="Refresh">
          <Icon name="refresh-cw" size="15" />
          <span class="hidden sm:inline">Refresh</span>
        </button>
      </div>
    </div>

    <!-- Loading skeleton -->
    <div id="history-loading" class="space-y-3">
      {[0, 1, 2].map(() => (
        <div class="glass-card p-4">
          <div class="space-y-2.5">
            <div class="skeleton-line h-3 w-1/4"></div>
            <div class="skeleton-line h-3 w-2/3"></div>
            <div class="skeleton-line h-3 w-1/2"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div
      id="history-empty"
      class="glass-card hidden flex-col items-center justify-center p-10 text-center"
    >
      <span class="flex h-12 w-12 items-center justify-center rounded-full bg-surface-2 text-ink-subtle">
        <Icon name="database" size="24" />
      </span>
      <h3 class="mt-4 text-base font-semibold tracking-tight text-ink">No analyses yet</h3>
      <p id="history-empty-text" class="mt-1.5 max-w-sm text-sm text-ink-subtle">
        Run the Loan, Credit, EMI, or AI Advisor tools and your results will be
        saved here automatically.
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        <a href="/loan-eligibility" class="btn-secondary h-9 px-3 text-sm">Loan Eligibility</a>
        <a href="/credit-score" class="btn-secondary h-9 px-3 text-sm">Credit Score</a>
        <a href="/emi-calculator" class="btn-secondary h-9 px-3 text-sm">EMI Calculator</a>
      </div>
    </div>

    <!-- No-results (search/filter) state -->
    <div id="history-noresults" class="glass-card hidden flex-col items-center justify-center p-10 text-center">
      <span class="flex h-12 w-12 items-center justify-center rounded-full bg-surface-2 text-ink-subtle">
        <Icon name="search" size="24" />
      </span>
      <h3 class="mt-4 text-base font-semibold tracking-tight text-ink">No matches</h3>
      <p class="mt-1.5 text-sm text-ink-subtle">Try a different search term or filter.</p>
    </div>

    <!-- Results count + list -->
    <div id="history-results" class="hidden space-y-3">
      <p id="history-count" class="text-xs text-ink-subtle"></p>
      <ul id="history-list" class="space-y-3"></ul>
    </div>
  </div>

  <!-- Detail modal -->
  <div
    id="detail-modal"
    class="fixed inset-0 z-[70] hidden items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="detail-title"
  >
    <div id="detail-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
    <div class="glass-card relative z-10 flex max-h-[85vh] w-full max-w-2xl flex-col overflow-hidden">
      <!-- Modal header -->
      <div class="flex items-start justify-between gap-3 border-b border-hairline p-5">
        <div class="min-w-0">
          <h2 id="detail-title" class="truncate font-display text-lg font-semibold tracking-tight text-ink">
            Analysis Detail
          </h2>
          <p id="detail-subtitle" class="mt-0.5 text-xs text-ink-subtle"></p>
        </div>
        <button id="detail-close" type="button" class="btn-secondary h-9 w-9 shrink-0 !p-0" aria-label="Close detail">
          <Icon name="x" size="16" />
        </button>
      </div>
      <!-- Modal body (populated client-side) -->
      <div id="detail-body" class="overflow-y-auto p-5"></div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { loadHistory, syncPending, pendingCount, getLocalRecords } from '../services/history';
  import type { AnalysisRecord } from '../services/types';
  import { formatInr } from '../utils/loan';
  import { renderMarkdown } from '../utils/markdown';
  import {
    formatTimestamp,
    relativeTime,
    loanStatusLabel,
    creditRatingLabel,
    recordTone,
    quickSummary,
    toolTags,
  } from '../utils/history-format';

  // ---- Elements -------------------------------------------------------------
  const loadingEl = document.getElementById('history-loading');
  const emptyEl = document.getElementById('history-empty');
  const noResultsEl = document.getElementById('history-noresults');
  const resultsEl = document.getElementById('history-results');
  const listEl = document.getElementById('history-list');
  const countEl = document.getElementById('history-count');
  const searchEl = document.getElementById('history-search') as HTMLInputElement | null;
  const filterEl = document.getElementById('history-filter') as HTMLSelectElement | null;
  const refreshBtn = document.getElementById('history-refresh') as HTMLButtonElement | null;
  const syncText = document.getElementById('sync-status-text');

  const modal = document.getElementById('detail-modal');
  const modalBackdrop = document.getElementById('detail-backdrop');
  const modalClose = document.getElementById('detail-close');
  const detailTitle = document.getElementById('detail-title');
  const detailSubtitle = document.getElementById('detail-subtitle');
  const detailBody = document.getElementById('detail-body');

  // ---- State ----------------------------------------------------------------
  let all: AnalysisRecord[] = [];
  const byId = new Map<string, AnalysisRecord>();

  const TONE_DOT: Record<string, string> = {
    green: 'bg-success',
    yellow: 'bg-[#d99e0b]',
    red: 'bg-[#e5484d]',
    none: 'bg-ink-tertiary',
  };

  // ---- Rendering ------------------------------------------------------------
  function esc(text: string): string {
    const d = document.createElement('div');
    d.textContent = text;
    return d.innerHTML;
  }

  function showOnly(which: 'loading' | 'empty' | 'noresults' | 'results') {
    loadingEl?.classList.toggle('hidden', which !== 'loading');
    emptyEl?.classList.toggle('hidden', which !== 'empty');
    emptyEl?.classList.toggle('flex', which === 'empty');
    noResultsEl?.classList.toggle('hidden', which !== 'noresults');
    noResultsEl?.classList.toggle('flex', which === 'noresults');
    resultsEl?.classList.toggle('hidden', which !== 'results');
  }

  function applyFilters(): AnalysisRecord[] {
    const q = (searchEl?.value ?? '').trim().toLowerCase();
    const f = filterEl?.value ?? 'all';
    return all.filter((r) => {
      if (f !== 'all' && r.source !== f) return false;
      if (!q) return true;
      const haystack = [
        r.name,
        loanStatusLabel(r),
        creditRatingLabel(r),
        quickSummary(r),
        r.loanPurpose,
      ]
        .join(' ')
        .toLowerCase();
      return haystack.includes(q);
    });
  }

  function render() {
    if (!listEl) return;
    if (all.length === 0) {
      showOnly('empty');
      return;
    }
    const rows = applyFilters();
    if (rows.length === 0) {
      showOnly('noresults');
      return;
    }

    const now = Date.now();
    listEl.innerHTML = '';
    for (const r of rows) {
      const tone = recordTone(r);
      const emi = r.monthlyEMI != null ? formatInr(r.monthlyEMI) : '—';
      const tags = toolTags(r)
        .map((t) => `<span class="history-tag">${esc(t)}</span>`)
        .join('');

      const li = document.createElement('li');
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'record-card';
      btn.dataset.id = r.id;
      btn.innerHTML = `
        <div class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full ${TONE_DOT[tone] ?? TONE_DOT.none}"></span>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
              <p class="truncate text-sm font-semibold text-ink">${esc(r.name || 'Untitled analysis')}</p>
              <span class="text-[11px] text-ink-tertiary">${esc(relativeTime(r.timestamp, now))}</span>
            </div>
            <p class="mt-0.5 truncate text-xs text-ink-subtle">${esc(quickSummary(r))}</p>
            <div class="mt-2 flex flex-wrap items-center gap-1.5">${tags}</div>
          </div>
          <div class="shrink-0 text-right">
            <p class="text-[11px] text-ink-tertiary">EMI</p>
            <p class="text-sm font-medium text-ink">${esc(emi)}</p>
          </div>
        </div>
        <div class="mt-3 flex items-center justify-between border-t border-hairline pt-2.5">
          <div class="flex items-center gap-3 text-[11px] text-ink-subtle">
            <span>Loan: <span class="text-ink-muted">${esc(loanStatusLabel(r))}</span></span>
            <span>Credit: <span class="text-ink-muted">${esc(creditRatingLabel(r))}</span></span>
          </div>
          <span class="flex items-center gap-1 text-[11px] font-medium text-primary-hover">
            View
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </span>
        </div>`;
      btn.addEventListener('click', () => openDetail(r.id));
      li.appendChild(btn);
      listEl.appendChild(li);
    }

    if (countEl) {
      countEl.textContent =
        rows.length === all.length
          ? `${all.length} ${all.length === 1 ? 'analysis' : 'analyses'}`
          : `${rows.length} of ${all.length} shown`;
    }
    showOnly('results');
  }

  // ---- Detail modal ---------------------------------------------------------
  function metricRow(label: string, value: string): string {
    return `<div class="flex items-center justify-between gap-3 py-1.5">
      <span class="text-xs text-ink-subtle">${esc(label)}</span>
      <span class="text-sm font-medium text-ink text-right">${esc(value)}</span>
    </div>`;
  }

  function section(title: string, inner: string): string {
    return `<section class="mt-4 first:mt-0">
      <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-ink-tertiary">${esc(title)}</h3>
      <div class="rounded-lg border border-hairline bg-surface-1/60 p-4">${inner}</div>
    </section>`;
  }

  function openDetail(id: string) {
    const r = byId.get(id);
    if (!r || !detailBody) return;

    if (detailTitle) detailTitle.textContent = r.name || 'Analysis Detail';
    if (detailSubtitle) detailSubtitle.textContent = formatTimestamp(r.timestamp);

    const blocks: string[] = [];

    if (r.loanEligibilityResult) {
      const l = r.loanEligibilityResult;
      blocks.push(section('Loan Eligibility',
        metricRow('Status', l.statusLabel) +
        metricRow('Risk', l.riskLabel) +
        metricRow('Eligible amount', formatInr(l.eligibleAmount)) +
        metricRow('Estimated EMI', `${formatInr(l.estimatedEmi)}/mo`) +
        metricRow('Interest rate', `${l.interestRate}% p.a.`) +
        metricRow('Debt-to-income', `${(l.debtToIncome * 100).toFixed(0)}%`)
      ));
    }

    if (r.creditAnalysis) {
      const c = r.creditAnalysis;
      blocks.push(section('Credit Analysis',
        metricRow('Score', `${c.score} (${c.rating})`) +
        metricRow('Risk', c.riskLabel) +
        metricRow('Financial health', `${c.financialHealth}/100 (${c.healthLabel})`) +
        metricRow('Approval probability', `${c.approvalProbability}%`) +
        metricRow('Time to improve', c.estimatedTimeToImprove)
      ));
    }

    if (r.emiCalculation) {
      const e = r.emiCalculation;
      blocks.push(section('EMI Calculation',
        metricRow('Loan type', e.loanTypeLabel) +
        metricRow('Monthly EMI', formatInr(e.monthlyEmi)) +
        metricRow('Principal', formatInr(e.principal)) +
        metricRow('Total interest', formatInr(e.totalInterest)) +
        metricRow('Total payment', formatInr(e.totalPayment)) +
        metricRow('Tenure', `${e.tenureMonths} months @ ${e.annualInterestRate.toFixed(2)}%`)
      ));
    }

    if (r.aiAdviceSummary) {
      blocks.push(section('AI Advice',
        `<div class="advisor-prose">${renderMarkdown(r.aiAdviceSummary)}</div>`
      ));
    }

    if (blocks.length === 0) {
      blocks.push(`<p class="text-sm text-ink-subtle">This record has no detailed results.</p>`);
    }

    detailBody.innerHTML = blocks.join('');
    openModal();
  }

  function openModal() {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
    (modalClose as HTMLButtonElement | null)?.focus();
  }

  function closeModal() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      closeModal();
    }
    if (e.key === 'Tab' && !modal?.classList.contains('hidden')) {
      const focusable = modal?.querySelectorAll<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      if (!focusable || focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }
  });

  // ---- Sync status ----------------------------------------------------------
  function updateSyncStatus() {
    if (!syncText) return;
    const offline = typeof navigator !== 'undefined' && navigator.onLine === false;
    const pending = pendingCount();
    if (offline) {
      syncText.textContent = pending > 0 ? `Offline · ${pending} to sync` : 'Offline';
    } else if (pending > 0) {
      syncText.textContent = `Syncing ${pending}…`;
    } else {
      syncText.textContent = 'All changes saved';
    }
  }

  // ---- Data loading ---------------------------------------------------------
  async function refresh() {
    showOnly('loading');
    // Flush any queued local records first so the cloud list is fresh.
    try { await syncPending(); } catch { /* ignore */ }

    all = await loadHistory();
    byId.clear();
    for (const r of all) byId.set(r.id, r);
    updateSyncStatus();
    render();
  }

  searchEl?.addEventListener('input', render);
  filterEl?.addEventListener('change', render);
  refreshBtn?.addEventListener('click', () => { void refresh(); });
  window.addEventListener('online', () => { void refresh(); });
  window.addEventListener('offline', updateSyncStatus);

  // Initial load: paint local instantly, then reconcile with the cloud.
  all = getLocalRecords();
  byId.clear();
  for (const r of all) byId.set(r.id, r);
  if (all.length > 0) { updateSyncStatus(); render(); }
  void refresh();
</script>
